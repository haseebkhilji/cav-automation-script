{
  "name": "cavago-automation-framework",
  "version": "1.0.0",
  "description": "QA automation framework for Cavago using Playwright with TypeScript and Allure reporting",
  "main": "playwright.config.ts",
  "scripts": {
    "test": "ENV=prod playwright test tests/smoke/login.spec.ts",
    "test:headed": "ENV=prod playwright test tests/smoke/login.spec.ts --headed",
    "report": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report:full": "npm run report && npm run report:open",
    "login": "ENV=prod ts-node scripts/login.ts",
    "login:headed": "ENV=prod ts-node scripts/login.ts",
    "book": "ENV=prod ts-node scripts/book-activity.ts",
    "book:headed": "ENV=prod ts-node scripts/book-activity.ts",
    "book:spec": "ENV=prod playwright test tests/smoke/booking.spec.ts",
    "book:spec:headed": "ENV=prod playwright test tests/smoke/booking.spec.ts --headed",
    "smoke:all": "ENV=prod playwright test tests/smoke/"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "allure",
    "cavago",
    "qa"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "allure-commandline": "^2.32.0",
    "allure-playwright": "^3.2.0",
    "dotenv": "^16.5.0",
    "@types/node": "^22.15.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
